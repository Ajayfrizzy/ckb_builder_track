# ─────────────────────────────────────────────────────────────────────────────
# InheritVault – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Email API URL (frontend)
# On Vercel this defaults to "/api/send-email" (no config needed).
# For local dev you can either:
#   1. Run `vercel dev --listen 3000` and keep the default /api/send-email, or
#   2. Point directly to a running backend:
# VITE_EMAIL_API_URL=http://localhost:3000/api/send-email

# Resend Configuration (set in Vercel dashboard → Environment Variables)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=InheritVault <noreply@yourdomain.com>
